# Stadium Coordinator — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Google Gemini API Key (required for AI features — future release)
GEMINI_API_KEY=your_gemini_api_key_here

# Streamlit environment (development | production)
STREAMLIT_ENV=development

# Logging level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# Application version
APP_VERSION=1.0.0
